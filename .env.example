# ============================================================
# .env.example — Environment Variables Template
# ============================================================
# This file is a TEMPLATE showing all available environment
# variables for this project.
#
# HOW TO USE:
#   1. Copy this file and rename the copy to ".env"
#      (no ".example" at the end)
#   2. Fill in your actual values in the .env file
#   3. NEVER commit your real .env file to Git!
#      It is already listed in .gitignore for you.
#
# GIT RULE: Always commit ".env.example" (this file) to show
# what variables are needed, but NOT the actual ".env" file.
# ============================================================


# --- Project Info ---
# The name that appears in the browser tab / page title
APP_NAME="OpenCollab Team Project"

# The public URL of the project (useful if you deploy it)
# Example: https://your-username.github.io/team-contribution-project
APP_URL="http://localhost"


# --- GitHub Settings (Optional) ---
# If you add a "Star on GitHub" feature or GitHub API calls,
# set the repository URL here instead of hardcoding it.
GITHUB_REPO_URL="https://github.com/your-username/team-contribution-project"

# GitHub personal access token — needed ONLY if you use the GitHub API.
# Get one at: https://github.com/settings/tokens
# KEEP THIS SECRET! Never share or commit this value.
GITHUB_TOKEN="your_github_token_here"


# --- Feature Flags ---
# Enable or disable features without changing code.
# Set to "true" or "false"
ENABLE_SEARCH="true"
ENABLE_ANIMATIONS="true"


# --- Analytics (Optional) ---
# If you add Google Analytics to the project, put your
# Measurement ID here.
# Format: G-XXXXXXXXXX
GA_MEASUREMENT_ID=""


# ============================================================
# NOTE FOR BEGINNERS:
# For this beginner project, you don't NEED a .env file to
# run index.html in your browser. Everything works without it.
# This file is here to teach the good habit of using .env
# files in real-world projects instead of hardcoding secrets.
# ============================================================
